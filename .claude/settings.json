{
  "model": "claude-sonnet-4-6",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{}' | bash /workspaces/Software-Factory/scripts/fetch-backlog.sh 2>/dev/null || true",
            "timeout": 10,
            "statusMessage": "Chargement du backlog..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash /workspaces/Software-Factory/scripts/autosave.sh 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "ignorePatterns": [
    "node_modules/**",
    ".next/**",
    "coverage/**",
    "dist/**",
    "build/**",
    ".vercel/**",
    "*.log",
    "logs/**",
    ".nyc_output/**",
    "*.min.js",
    "*.min.css",
    "package-lock.json",
    "yarn.lock",
    "pnpm-lock.yaml"
  ]
}
